    {
      "parameters": {
        "jsCode": "const doc = $input.first().json;\nconst content = doc.body?.content || doc.text || JSON.stringify(doc);\nlet text = typeof content === 'string' ? content : JSON.stringify(content);\ntext = text.replace(/\\\\s+/g, ' ').trim();\n\nif (text.length <= 3000) {\n  return [{ json: { transcript_summary: text, is_chunked: false } }];\n}\n\nconst first = text.substring(0, 1500);\nconst last = text.substring(text.length - 1500);\nconst middleChunks = [];\nconst step = Math.floor(text.length / 6);\nfor (let i = 1; i <= 4; i++) {\n  const pos = step * i;\n  const block = text.substring(pos, pos + 200);\n  const sentence = block.split(/[.!?]/)[0];\n  if (sentence) middleChunks.push(sentence.trim());\n}\n\nconst summary = `[START]\\n${first}\\n\\n[KEY MIDDLE SECTIONS]\\n${middleChunks.join('\\n')}\\n\\n[END]\\n${last}`;\nreturn [{ json: { transcript_summary: summary, is_chunked: true, original_length: text.length } }];\n"
      },
