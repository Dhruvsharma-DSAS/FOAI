    {
      "parameters": {
        "jsCode": "// Get data from 3 different nodes\nconst data1 = $items(\"Student Data\").map(item => item.json); // Main student data\nconst data2 = $items(\"Convert Sentiment into score\").map(item => item.json); // Feedback data\nconst data3 = $items(\"Teacher Feedback\").map(item => item.json); // Teacher data\n\n// Create maps\nconst map2 = {};\ndata2.forEach(item => {\n    map2[item.student_id] = item;\n});\n\nconst map3 = {};\ndata3.forEach(item => {\n    map3[item.ID] = item;\n});\n\n// Merge\nconst result = data1.map(student => {\n    const id = student[\"Student ID\"];\n\n    return {\n        ...student,\n        feedback_level: map2[id]?.feedback_level || null,\n        teacher_data: map3[id] ? {\n            \"Teacher Participation\": map3[id][\"Teacher Participation\"],\n            \"Teacher Attention\": map3[id][\"Teacher Attention\"],\n            \"Teacher Understanding\": map3[id][\"Teacher Understanding\"],\n            \"Effort\": map3[id][\"Effort\"],\n            \"Teacher Remark\": map3[id][\"Teacher Remark\"]\n        } : null\n    };\n});\n\n\nreturn [\n  {\n    json: {\n      students: result\n    }\n  }\n];"
      },
