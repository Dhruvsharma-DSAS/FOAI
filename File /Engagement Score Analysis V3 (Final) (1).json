    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  let raw = item.json.text || \"\";\n\n  // 🧹 remove markdown\n  let clean = raw\n    .replace(/```json/g, \"\")\n    .replace(/```/g, \"\")\n    .trim();\n\n  let parsed;\n  try {\n    parsed = JSON.parse(clean);\n  } catch (e) {\n    return { json: { error: \"Invalid JSON\", raw } };\n  }\n\n  // 🔄 unify root\n  const data =\n    parsed.analysis ||\n    parsed.evaluation ||\n    {};\n\n  // ✅ helper to extract topics safely\n  const extractTopics = (arr) => {\n    if (!Array.isArray(arr)) return [];\n    return arr.map(i =>\n      typeof i === \"string\" ? i : i?.topic\n    ).filter(Boolean);\n  };\n\n  // 📚 normalize\n  const covered = extractTopics(\n    data.covered || data.covered_topics\n  );\n\n  const missed = extractTopics(\n    data.missed || data.missed_topics\n  );\n\n  const partial = extractTopics(\n    data.partial || data.partially_covered_topics\n  );\n\n  // ⏱️ off-topic (safe)\n  let offTopicTime = 0;\n\n  const off = data[\"off-topic\"] || data[\"off-topic_content\"];\n\n  if (typeof off === \"string\") {\n    offTopicTime = parseFloat(off) || 0;\n  }\n\n  // ✅ final output\n  return {\n    json: {\n      covered,\n      missed,\n      partial,\n      off_topic_time: offTopicTime + \" minutes\",\n      match_percentage: data.match_percentage || 0,\n      rating: data.rating || \"UNKNOWN\"\n    }\n  };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        640
      ],
      "id": "4fb10561-40e2-41e0-b90d-22c2e1a5ce8b",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const d = item.json;\n\n  return {\n    json: {\n      name: d[\"Student Name\"],\n      id: d.ID,\n      email: d.Email,\n      understanding: d[\"Understanding (Student)\"],\n      quiz_score: d[\"Quiz (%)\"],\n      interest: d.Interest,\n      doubt_level:\n        d.Doubt === \"None\" ? \"LOW\" :\n        d.Doubt === \"Some\" ? \"MEDIUM\" : \"HIGH\",\n      pace: d.Pace.toUpperCase(),\n      assignment_score: d.Assignment,\n      feedback: d.Feedback,\n      teacher_metrics: {\n        participation: d[\"Teacher Participation\"],\n        attention: d[\"Teacher Attention\"],\n        understanding: d[\"Teacher Understanding\"]\n      },\n      effort: d.Effort,\n      teacher_remark: d[\"Teacher Remark\"],\n      topic_difficulty: d[\"Topic Difficulty\"].toUpperCase(),\n      suggested_improvement: d[\"Suggested Improvement\"],\n      feedback_sentiment: d.feedback_level.toUpperCase(),\n      student_score: d[\"Student Score\"],\n      teacher_score: d[\"Teacher Score\"],\n      engagement_score: d[\"Final Engagement Score\"],\n      risk_level: d.Risk.replace(\" Risk\", \"\").toUpperCase()\n    }\n  };\n});"
      },
