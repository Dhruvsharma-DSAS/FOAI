    {
      "parameters": {
        "jsCode": "// This script processes each item coming from the AI node\n// and converts the stringified ID-based objects into flat table rows.\n\nconst results = [];\n\n// Loop through every item entering the node\nfor (const item of $input.all()) {\n  try {\n    // 1. Parse the string inside the \"text\" field\n    const parsedText = JSON.parse(item.json.text);\n    \n    // 2. Since the ID (like \"101\") is the key, get that key\n    const studentId = Object.keys(parsedText)[0];\n    const studentData = parsedText[studentId];\n\n    // 3. Push a clean object into our results array\n    results.push({\n      json: {\n        student_id: studentId,\n        student_name: studentData.student_name,\n        feedback_level: studentData.feedback_level\n      }\n    });\n  } catch (error) {\n    // If an item is empty or invalid, we skip it to prevent crashing\n    continue;\n  }\n}\n\nreturn results;"
      },
      "id": "ea4953a7-2cce-4677-8453-9ed8f62c0d63",
      "name": "Convert Sentiment into score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        -80
      ]
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n\n  // ---------- STUDENT ----------\n  const U = Number(item.json[\"Understanding (Student)\"] || 0) * 10;\n  const Q = Number(item.json[\"Quiz (%)\"] || 0);\n  const I = Number(item.json[\"Interest\"] || 0) * 10;\n  const A = Number(item.json[\"Assignment\"] || 0);\n\n  // ---------- DOUBT ----------\n  let doubtScore = 60;\n  if (item.json[\"Doubt\"] === \"None\") doubtScore = 100;\n  else if (item.json[\"Doubt\"] === \"Many\") doubtScore = 30;\n\n  // ---------- PACE ----------\n  let paceScore = 100;\n  if (item.json[\"Pace\"] === \"Slow\") paceScore = 70;\n  else if (item.json[\"Pace\"] === \"Fast\") paceScore = 50;\n\n  // ---------- STUDENT SCORE ----------\n  const studentScore =\n    (0.25 * U) +\n    (0.25 * Q) +\n    (0.15 * I) +\n    (0.15 * A) +\n    (0.10 * doubtScore) +\n    (0.10 * paceScore);\n\n  // ---------- TEACHER ----------\n  const TP = Number(item.json[\"Teacher Participation\"] || 0) * 10;\n  const TA = Number(item.json[\"Teacher Attention\"] || 0) * 10;\n  const TU = Number(item.json[\"Teacher Understanding\"] || 0) * 10;\n  const E  = Number(item.json[\"Effort\"] || 0) * 10;\n\n  const teacherScore =\n    (0.30 * TP) +\n    (0.25 * TA) +\n    (0.25 * TU) +\n    (0.20 * E);\n\n  // ---------- FEEDBACK ----------\n  let feedbackScore = 60;\n  if (item.json[\"feedback_level\"] === \"Positive\") feedbackScore = 100;\n  else if (item.json[\"feedback_level\"] === \"Negative\") feedbackScore = 30;\n\n  // ---------- FINAL SCORE ----------\n  const finalScore =\n    (0.6 * studentScore) +\n    (0.3 * teacherScore) +\n    (0.1 * feedbackScore);\n\n  // ---------- RISK LOGIC ----------\n  let risk = \"High Risk\";\n  if (finalScore >= 75) risk = \"Low Risk\";\n  else if (finalScore >= 50) risk = \"Medium Risk\";\n\n  // ---------- RETURN ----------\n  return {\n    json: {\n      ...item.json,\n      \"Student Score\": Math.round(studentScore),\n      \"Teacher Score\": Math.round(teacherScore),\n      \"Final Engagement Score\": Math.round(finalScore),\n      \"Risk\": risk\n    }\n  };\n\n});"
      },
