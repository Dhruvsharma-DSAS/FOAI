    {
      "parameters": {
        "jsCode": "// 🧠 initialize combined result\nlet combined = {\n  covered: new Set(),\n  missed: new Set(),\n  partial: new Set(),\n  off_topic_time: 0,\n  match_percentage: [],\n  rating: []\n};\n\nitems.forEach(item => {\n  const d = item.json;\n\n  // ✅ merge arrays (avoid duplicates using Set)\n  (d.covered || []).forEach(t => combined.covered.add(t));\n  (d.missed || []).forEach(t => combined.missed.add(t));\n  (d.partial || []).forEach(t => combined.partial.add(t));\n\n  // ⏱️ sum off-topic time\n  if (d.off_topic_time) {\n    combined.off_topic_time += parseFloat(d.off_topic_time) || 0;\n  }\n\n  // 📊 collect percentages\n  if (d.match_percentage !== undefined) {\n    combined.match_percentage.push(d.match_percentage);\n  }\n\n  // ⭐ collect ratings\n  if (d.rating) {\n    combined.rating.push(d.rating);\n  }\n});\n\n\n// 🎯 final output\nreturn [{\n  json: {\n    covered: Array.from(combined.covered),\n    missed: Array.from(combined.missed),\n    partial: Array.from(combined.partial),\n\n    off_topic_time: combined.off_topic_time + \" minutes\",\n\n    match_percentage:\n      combined.match_percentage.length\n        ? Math.round(\n            combined.match_percentage.reduce((a, b) => a + b, 0) /\n            combined.match_percentage.length\n          )\n        : 0,\n\n    rating: combined.rating.includes(\"POOR\")\n      ? \"POOR\"\n      : combined.rating.includes(\"AVERAGE\")\n      ? \"AVERAGE\"\n      : \"GOOD\"\n  }\n}];"
      },
